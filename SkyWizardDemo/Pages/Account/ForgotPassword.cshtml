@page
@model SkyWizardDemo.Pages.Account.ForgotPasswordModel
@{
    Layout = "_LayoutSetup";
    ViewData["Title"] = "Forgot Password";
    ViewData["BodyClass"] = "wizard-theme wizard-step-forgot-password";
}

<div class="forgot-password-container">
    <main>
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <h1 class="wizard-title text-center">Forgot Your Password?</h1>
                <p class="wizard-subtitle text-center mx-auto mb-4">
                    Enter your email to receive a password reset link
                </p>

                <div class="wizard-card">
                    <div class="wizard-card-body">
                        @if (Model.EmailSent)
                        {
                            <div class="wizard-alert wizard-alert-info mb-3">
                                <i class="fa-solid fa-circle-check me-2"></i>
                                <strong>Email Sent!</strong> Please check your email for password reset instructions.
                            </div>
                            <div class="wizard-tile">
                                <h4>Next Steps:</h4>
                                <ul class="wizard-list">
                                    <li>Check your inbox for the password reset email</li>
                                    <li>Click the link in the email to reset your password</li>
                                    <li>The link will expire in 24 hours</li>
                                    <li>Check your spam folder if you don't see the email</li>
                                </ul>
                            </div>
                            <div class="wizard-actions">
                                <a asp-page="./Login" class="btn btn-sky-primary w-100">
                                    <i class="fa-solid fa-right-to-bracket me-1"></i> Back to Login
                                </a>
                            </div>
                        }
                        else
                        {
                            <form method="post">
                                @if (!ViewData.ModelState.IsValid)
                                {
                                    <div asp-validation-summary="All" class="wizard-alert wizard-alert-info mb-3"></div>
                                }

                                <div class="wizard-alert wizard-alert-note mb-3">
                                    <i class="fa-solid fa-circle-info me-2"></i>
                                    Enter the email address associated with your account and we'll send you a link to reset your password.
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Input.Email" class="wizard-form-label">
                                        Email Address <span class="wizard-required">*</span>
                                    </label>
                                    <input asp-for="Input.Email" class="form-control" placeholder="your@email.com" autofocus />
                                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                                </div>

                                <div class="wizard-actions">
                                    <a asp-page="./Login" class="btn btn-sky-secondary">
                                        <i class="fa-solid fa-arrow-left me-1"></i> Back to Login
                                    </a>
                                    <button type="submit" class="btn btn-sky-primary">
                                        <i class="fa-solid fa-paper-plane me-1"></i> Send Reset Link
                                    </button>
                                </div>
                            </form>

                            <hr class="my-4" />
                            <div class="text-center">
                                <p class="mb-2">Remember your password?</p>
                                <a asp-page="./Login" class="btn btn-sky-secondary btn-sm">
                                    <i class="fa-solid fa-right-to-bracket me-1"></i> Log In
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
