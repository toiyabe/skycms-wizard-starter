@page
@model SkyWizardDemo.Pages.Account.Manage.ChangePasswordModel
@{
    Layout = "_LayoutSetup";
    ViewData["Title"] = "Change Password";
    ViewData["BodyClass"] = "wizard-theme wizard-step-change-password";
}

<div class="change-password-container">
    <main>
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <h1 class="wizard-title">Change Password</h1>
                <p class="wizard-subtitle">Update your password to keep your account secure</p>

                @if (Model.StatusMessage != null)
                {
                    <div class="wizard-alert wizard-alert-info mb-3">
                        <i class="fa-solid fa-circle-check me-2"></i>
                        @Model.StatusMessage
                    </div>
                }

                <div class="wizard-card">
                    <div class="wizard-card-body">
                        <form method="post">
                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div asp-validation-summary="All" class="wizard-alert wizard-alert-info mb-3"></div>
                            }

                            <div class="mb-3">
                                <label asp-for="Input.OldPassword" class="wizard-form-label">
                                    Current Password <span class="wizard-required">*</span>
                                </label>
                                <input asp-for="Input.OldPassword" class="form-control" placeholder="Enter current password" />
                                <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.NewPassword" class="wizard-form-label">
                                    New Password <span class="wizard-required">*</span>
                                </label>
                                <input asp-for="Input.NewPassword" class="form-control" placeholder="Enter new password" />
                                <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.ConfirmPassword" class="wizard-form-label">
                                    Confirm New Password <span class="wizard-required">*</span>
                                </label>
                                <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="Re-enter new password" />
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                            </div>

                            <div class="wizard-tile mb-3">
                                <h4><i class="fa-solid fa-shield-halved me-2"></i>Password Requirements</h4>
                                <ul id="passwordRules" class="wizard-list mb-0">
                                    <li><i class="fa-regular fa-circle me-1"></i> At least 8 characters long</li>
                                    <li><i class="fa-regular fa-circle me-1"></i> Contains uppercase letter</li>
                                    <li><i class="fa-regular fa-circle me-1"></i> Contains lowercase letter</li>
                                    <li><i class="fa-regular fa-circle me-1"></i> Contains number</li>
                                    <li><i class="fa-regular fa-circle me-1"></i> Contains special character</li>
                                </ul>
                            </div>

                            <div class="wizard-actions">
                                <a asp-page="./Index" class="btn btn-sky-secondary">
                                    <i class="fa-solid fa-arrow-left me-1"></i> Cancel
                                </a>
                                <button type="submit" class="btn btn-sky-primary">
                                    <i class="fa-solid fa-key me-1"></i> Update Password
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="wizard-alert wizard-alert-note">
                    <i class="fa-solid fa-lightbulb me-2"></i>
                    <strong>Tip:</strong> Use a password manager to generate and store strong, unique passwords.
                </div>
            </div>
        </div>
    </main>
</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script src="~/js/register-validation.js"></script>
}
