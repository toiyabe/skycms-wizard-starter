@page
@model SkyWizardDemo.Pages.Account.RegisterModel
@{
    Layout = "_LayoutSetup";
    ViewData["Title"] = "Register";
    ViewData["BodyClass"] = "wizard-theme wizard-step-register";
}

<div class="register-container">
    <main>
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <h1 class="wizard-title text-center">Create Your Account</h1>
                <p class="wizard-subtitle text-center mx-auto mb-4">
                    Join SkyCMS and start managing your content
                </p>

                <div class="wizard-card">
                    <div class="wizard-card-body">
                        <div class="text-center mb-4">
                            <p class="mb-2">Already have an account?</p>
                            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-sky-secondary btn-sm">
                                <i class="fa-solid fa-right-to-bracket me-1"></i> Log In
                            </a>
                        </div>

                        <form method="post" asp-antiforgery="true">
                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div asp-validation-summary="All" class="wizard-alert wizard-alert-info mb-3"></div>
                            }

                            <div class="mb-3">
                                <label asp-for="Input.Email" class="wizard-form-label">
                                    Email <span class="wizard-required">*</span>
                                </label>
                                <input asp-for="Input.Email" class="form-control" placeholder="your@email.com" />
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.Password" class="wizard-form-label">
                                    Password <span class="wizard-required">*</span>
                                </label>
                                <input asp-for="Input.Password" class="form-control" placeholder="Create a strong password" />
                                <span asp-validation-for="Input.Password" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.ConfirmPassword" class="wizard-form-label">
                                    Confirm Password <span class="wizard-required">*</span>
                                </label>
                                <input asp-for="Input.ConfirmPassword" class="form-control" placeholder="Re-enter your password" />
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                            </div>

                            <div class="wizard-tile mb-3">
                                <h4><i class="fa-solid fa-shield-halved me-2"></i>Password Requirements</h4>
                                <ul id="passwordRules" class="wizard-list mb-0">
                                    <li><i class="fa-regular fa-circle me-1"></i> At least 8 characters long</li>
                                    <li><i class="fa-regular fa-circle me-1"></i> Contains uppercase letter</li>
                                    <li><i class="fa-regular fa-circle me-1"></i> Contains lowercase letter</li>
                                    <li><i class="fa-regular fa-circle me-1"></i> Contains number</li>
                                    <li><i class="fa-regular fa-circle me-1"></i> Contains special character</li>
                                </ul>
                            </div>

                            <div class="wizard-alert wizard-alert-note mb-3">
                                <i class="fa-solid fa-circle-info me-2"></i>
                                By registering, you agree to our Terms of Service and Privacy Policy.
                            </div>

                            <div class="wizard-actions">
                                <a href="@Url.Page("/Index")" class="btn btn-sky-secondary">
                                    <i class="fa-solid fa-arrow-left me-1"></i> Cancel
                                </a>
                                <button type="submit" class="btn btn-sky-primary">
                                    <i class="fa-solid fa-user-plus me-1"></i> Create Account
                                </button>
                            </div>
                        </form>

                        @if (Model.ExternalLogins?.Count > 0)
                        {
                            <hr class="my-4" />
                            <h4 class="text-center mb-3">Or register with</h4>

                            <form asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                                <div class="d-grid gap-2">
                                    @foreach (var provider in Model.ExternalLogins)
                                    {
                                        @if (provider.Name == "Google")
                                        {
                                            <button type="submit" name="provider" value="@provider.Name" class="btn btn-outline-secondary">
                                                <i class="fa-brands fa-google me-2"></i> Register with @provider.DisplayName
                                            </button>
                                        }
                                        else if (provider.Name == "Microsoft")
                                        {
                                            <button type="submit" name="provider" value="@provider.Name" class="btn btn-outline-secondary">
                                                <i class="fa-brands fa-microsoft me-2"></i> Register with @provider.DisplayName
                                            </button>
                                        }
                                    }
                                </div>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/register-validation.js"></script>
}
