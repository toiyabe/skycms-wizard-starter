@page
@model IndexModel
@{
    Layout = "_LayoutSetup";
    ViewData["Title"] = "SkyCMS Demo - Home";
    ViewData["BodyClass"] = "wizard-theme wizard-step-demo-home";
}

<div class="demo-home-container">
    <main>
        <h1 class="wizard-title text-center">SkyCMS Liquid Glass Demo</h1>
        <p class="wizard-subtitle text-center mx-auto">
            Explore all screens with the beautiful liquid glass theme
        </p>

        <div class="wizard-card">
            <div class="wizard-card-head">
                <i class="fa-solid fa-rocket me-2"></i> Setup Wizard Screens
            </div>
            <div class="wizard-card-body">
                <div class="row g-3">
                    <div class="col-md-6 col-lg-4">
                        <a href="@Url.Page("/Setup/Welcome")" class="wizard-tile text-decoration-none d-block h-100">
                            <h4><i class="fa-solid fa-hand-wave me-2 text-primary"></i>Welcome</h4>
                            <p class="mb-0">Initial setup wizard welcome screen</p>
                        </a>
                    </div>
                    <div class="col-md-6 col-lg-4">
                        <a href="@Url.Page("/Setup/Storage")" class="wizard-tile text-decoration-none d-block h-100">
                            <h4><i class="fa-solid fa-database me-2 text-primary"></i>Storage</h4>
                            <p class="mb-0">Configure storage settings</p>
                        </a>
                    </div>
                    <div class="col-md-6 col-lg-4">
                        <a href="@Url.Page("/Setup/Admin")" class="wizard-tile text-decoration-none d-block h-100">
                            <h4><i class="fa-solid fa-user-shield me-2 text-primary"></i>Admin</h4>
                            <p class="mb-0">Create administrator account</p>
                        </a>
                    </div>
                    <div class="col-md-6 col-lg-4">
                        <a href="@Url.Page("/Setup/Publisher")" class="wizard-tile text-decoration-none d-block h-100">
                            <h4><i class="fa-solid fa-globe me-2 text-primary"></i>Publisher</h4>
                            <p class="mb-0">Configure publisher settings</p>
                        </a>
                    </div>
                    <div class="col-md-6 col-lg-4">
                        <a href="@Url.Page("/Setup/Email")" class="wizard-tile text-decoration-none d-block h-100">
                            <h4><i class="fa-solid fa-envelope me-2 text-primary"></i>Email</h4>
                            <p class="mb-0">Set up email service</p>
                        </a>
                    </div>
                    <div class="col-md-6 col-lg-4">
                        <a href="@Url.Page("/Setup/Cdn")" class="wizard-tile text-decoration-none d-block h-100">
                            <h4><i class="fa-solid fa-network-wired me-2 text-primary"></i>CDN</h4>
                            <p class="mb-0">Content delivery network setup</p>
                        </a>
                    </div>
                    <div class="col-md-6 col-lg-4">
                        <a href="@Url.Page("/Setup/Review")" class="wizard-tile text-decoration-none d-block h-100">
                            <h4><i class="fa-solid fa-check-circle me-2 text-success"></i>Review</h4>
                            <p class="mb-0">Review and complete setup</p>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="wizard-card">
            <div class="wizard-card-head">
                <i class="fa-solid fa-cog me-2"></i> Management Screens (New)
            </div>
            <div class="wizard-card-body">
                <div class="row g-3">
                    <div class="col-md-6 col-lg-4">
                        <a href="@Url.Page("/PageInventory")" class="wizard-tile text-decoration-none d-block h-100">
                            <h4><i class="fa-solid fa-file-lines me-2 text-primary"></i>Page Inventory</h4>
                            <p class="mb-0">Manage all website pages</p>
                        </a>
                    </div>
                    <div class="col-md-6 col-lg-4">
                        <a href="@Url.Page("/TemplateInventory")" class="wizard-tile text-decoration-none d-block h-100">
                            <h4><i class="fa-solid fa-layer-group me-2 text-primary"></i>Template Inventory</h4>
                            <p class="mb-0">Manage page templates</p>
                        </a>
                    </div>
                    <div class="col-md-6 col-lg-4">
                        <a href="@Url.Page("/PublishWebsite")" class="wizard-tile text-decoration-none d-block h-100">
                            <h4><i class="fa-solid fa-rocket me-2 text-primary"></i>Publish Website</h4>
                            <p class="mb-0">Deploy changes to live site</p>
                        </a>
                    </div>
                    <div class="col-md-6 col-lg-4">
                        <a href="@Url.Page("/EditorSetup")" class="wizard-tile text-decoration-none d-block h-100">
                            <h4><i class="fa-solid fa-gear me-2 text-primary"></i>Editor Setup</h4>
                            <p class="mb-0">Configure editor settings</p>
                        </a>
                    </div>
                    <div class="col-md-6 col-lg-4">
                        <a href="@Url.Page("/CdnSetup")" class="wizard-tile text-decoration-none d-block h-100">
                            <h4><i class="fa-solid fa-network-wired me-2 text-primary"></i>CDN Setup</h4>
                            <p class="mb-0">Configure content delivery network</p>
                        </a>
                    </div>
                    <div class="col-md-6 col-lg-4">
                        <a href="@Url.Page("/FileExplorer")" class="wizard-tile text-decoration-none d-block h-100">
                            <h4><i class="fa-solid fa-folder-open me-2 text-primary"></i>File Explorer</h4>
                            <p class="mb-0">Browse and manage website files</p>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="wizard-alert wizard-alert-info">
            <i class="fa-solid fa-circle-info me-2"></i>
            <strong>Note:</strong> All screens feature the liquid glass theme with unique container classnames for easy targeting.
        </div>
    </main>
