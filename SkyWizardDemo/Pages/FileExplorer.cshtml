@page
@model SkyWizardDemo.Pages.FileExplorerModel
@{
    Layout = "_LayoutSetup";
    ViewData["Title"] = "File Explorer";
    ViewData["BodyClass"] = "wizard-theme wizard-step-file-explorer";
}

<div class="file-explorer-container">
    <main>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h1 class="wizard-title mb-2">File Explorer</h1>
                <p class="wizard-subtitle mb-0">Browse and manage your website files</p>
            </div>
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-sky-primary btn-sm" id="btnBigIcons" onclick="toggleView('bigIcons')">
                    <i class="fa-solid fa-grid-2 me-1"></i> Big Icons
                </button>
                <button type="button" class="btn btn-sky-secondary btn-sm" id="btnSmallIcons" onclick="toggleView('smallIcons')">
                    <i class="fa-solid fa-grid me-1"></i> Small Icons
                </button>
                <button type="button" class="btn btn-sky-secondary btn-sm" id="btnList" onclick="toggleView('list')">
                    <i class="fa-solid fa-list me-1"></i> List
                </button>
                <button type="button" class="btn btn-sky-secondary btn-sm" id="btnDetails" onclick="toggleView('details')">
                    <i class="fa-solid fa-table-list me-1"></i> Details
                </button>
            </div>
        </div>

        <div class="wizard-card mb-3">
            <div class="wizard-card-body">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0" style="background: transparent;">
                        <li class="breadcrumb-item">
                            <a href="#" class="text-decoration-none">
                                <i class="fa-solid fa-house me-1"></i> Home
                            </a>
                        </li>
                        @foreach (var folder in Model.CurrentPath)
                        {
                            <li class="breadcrumb-item active" aria-current="page">@folder</li>
                        }
                    </ol>
                </nav>
            </div>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-8">
                <div class="wizard-card">
                    <div class="wizard-card-head">
                        <div class="d-flex justify-content-between align-items-center">
                            <span><i class="fa-solid fa-folder-open me-2"></i> Files & Folders</span>
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-sky-primary btn-sm">
                                    <i class="fa-solid fa-upload me-1"></i> Upload
                                </button>
                                <button type="button" class="btn btn-sky-secondary btn-sm">
                                    <i class="fa-solid fa-folder-plus me-1"></i> New Folder
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="wizard-card-body">
                        <!-- Big Icons View -->
                        <div id="bigIconsView" class="file-view">
                            <div class="row g-3">
                                @foreach (var item in Model.Items)
                                {
                                    <div class="col-md-3 col-sm-4 col-6">
                                        <div class="file-item @(item.IsFolder ? "folder-item" : "file-item")" onclick="selectItem('@item.Name')" style="cursor: pointer; padding: 1rem; border-radius: 8px; transition: background 0.2s;">
                                            <div class="file-icon text-center">
                                                @if (item.IsFolder)
                                                {
                                                    <i class="fa-solid fa-folder" style="font-size: 3rem; color: #3996ff;"></i>
                                                }
                                                else if (item.IsImage)
                                                {
                                                    <i class="fa-solid fa-file-image" style="font-size: 3rem; color: #22c55e;"></i>
                                                }
                                                else
                                                {
                                                    <i class="fa-solid fa-file" style="font-size: 3rem; color: #6b7280;"></i>
                                                }
                                            </div>
                                            <div class="file-name text-center mt-2">
                                                <small><strong>@item.Name</strong></small>
                                                @if (!item.IsFolder)
                                                {
                                                    <br />
                                                    <small class="text-muted">@item.Size</small>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Small Icons View -->
                        <div id="smallIconsView" class="file-view" style="display: none;">
                            <div class="row g-2">
                                @foreach (var item in Model.Items)
                                {
                                    <div class="col-md-2 col-sm-3 col-4">
                                        <div class="file-item @(item.IsFolder ? "folder-item" : "file-item")" onclick="selectItem('@item.Name')" style="cursor: pointer; padding: 0.5rem; border-radius: 6px; transition: background 0.2s;">
                                            <div class="file-icon text-center">
                                                @if (item.IsFolder)
                                                {
                                                    <i class="fa-solid fa-folder" style="font-size: 1.5rem; color: #3996ff;"></i>
                                                }
                                                else if (item.IsImage)
                                                {
                                                    <i class="fa-solid fa-file-image" style="font-size: 1.5rem; color: #22c55e;"></i>
                                                }
                                                else
                                                {
                                                    <i class="fa-solid fa-file" style="font-size: 1.5rem; color: #6b7280;"></i>
                                                }
                                            </div>
                                            <div class="file-name text-center mt-1">
                                                <small style="font-size: 0.75rem;"><strong>@item.Name</strong></small>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- List View -->
                        <div id="listView" class="file-view" style="display: none;">
                            <div class="list-group">
                                @foreach (var item in Model.Items)
                                {
                                    <div class="list-group-item list-group-item-action d-flex align-items-center" onclick="selectItem('@item.Name')" style="cursor: pointer; border-radius: 6px; margin-bottom: 0.25rem;">
                                        @if (item.IsFolder)
                                        {
                                            <i class="fa-solid fa-folder me-3" style="font-size: 1.25rem; color: #3996ff; width: 24px;"></i>
                                        }
                                        else if (item.IsImage)
                                        {
                                            <i class="fa-solid fa-file-image me-3" style="font-size: 1.25rem; color: #22c55e; width: 24px;"></i>
                                        }
                                        else
                                        {
                                            <i class="fa-solid fa-file me-3" style="font-size: 1.25rem; color: #6b7280; width: 24px;"></i>
                                        }
                                        <div class="flex-grow-1">
                                            <strong>@item.Name</strong>
                                        </div>
                                        @if (!item.IsFolder)
                                        {
                                            <span class="text-muted me-3">@item.Size</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Details View -->
                        <div id="detailsView" class="file-view" style="display: none;">
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th style="width: 40%;">Name</th>
                                            <th style="width: 15%;">Type</th>
                                            <th style="width: 15%;">Size</th>
                                            <th style="width: 20%;">Modified</th>
                                            <th style="width: 10%;" class="text-center">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.Items)
                                        {
                                            <tr style="vertical-align: middle;">
                                                <td>
                                                    @if (item.IsFolder)
                                                    {
                                                        <i class="fa-solid fa-folder me-2 text-primary"></i>
                                                    }
                                                    else if (item.IsImage)
                                                    {
                                                        <i class="fa-solid fa-file-image me-2 text-success"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="fa-solid fa-file me-2"></i>
                                                    }
                                                    <strong>@item.Name</strong>
                                                </td>
                                                <td>@item.Type</td>
                                                <td>@item.Size</td>
                                                <td>@item.Modified.ToString("MMM dd, yyyy h:mm tt")</td>
                                                <td class="text-center">
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <button type="button" class="btn btn-secondary btn-sm" title="Download">
                                                            <i class="fa-solid fa-download"></i>
                                                        </button>
                                                        <button type="button" class="btn btn-secondary btn-sm" title="Rename">
                                                            <i class="fa-solid fa-pen"></i>
                                                        </button>
                                                        <button type="button" class="btn btn-danger btn-sm" title="Delete">
                                                            <i class="fa-solid fa-trash"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="wizard-card">
                    <div class="wizard-card-head">
                        <i class="fa-solid fa-circle-info me-2"></i> File Details
                    </div>
                    <div class="wizard-card-body">
                        <div id="fileDetails" class="text-center py-4">
                            <i class="fa-solid fa-hand-pointer" style="font-size: 3rem; color: #cbd5e1;"></i>
                            <p class="mt-3 mb-0 text-muted">Select a file to view details</p>
                        </div>
                    </div>
                </div>

                <div class="wizard-card mt-3">
                    <div class="wizard-card-head">
                        <i class="fa-solid fa-chart-simple me-2"></i> Storage Usage
                    </div>
                    <div class="wizard-card-body">
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span>Used</span>
                                <strong>2.4 GB / 10 GB</strong>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-success" role="progressbar" style="width: 24%" aria-valuenow="24" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                        <div class="wizard-tile">
                            <h4><i class="fa-solid fa-folder me-2 text-primary"></i>Folders</h4>
                            <p class="mb-0">@Model.Items.Count(i => i.IsFolder) folders</p>
                        </div>
                        <div class="wizard-tile mt-2">
                            <h4><i class="fa-solid fa-file me-2 text-success"></i>Files</h4>
                            <p class="mb-0">@Model.Items.Count(i => !i.IsFolder) files</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="wizard-actions">
            <a href="@Url.Page("/Index")" class="btn btn-sky-secondary">
                <i class="fa-solid fa-arrow-left me-1"></i> Back to Dashboard
            </a>
        </div>
    </main>
</div>

@section Scripts {
    <script>
        function toggleView(view) {
            // Hide all views
            const views = ['bigIconsView', 'smallIconsView', 'listView', 'detailsView'];
            views.forEach(v => {
                const element = document.getElementById(v);
                if (element) element.style.display = 'none';
            });

            // Show selected view
            const selectedView = document.getElementById(view + 'View');
            if (selectedView) selectedView.style.display = 'block';

            // Update button states
            const buttons = ['btnBigIcons', 'btnSmallIcons', 'btnList', 'btnDetails'];
            buttons.forEach(btnId => {
                const btn = document.getElementById(btnId);
                if (btn) {
                    btn.classList.remove('btn-sky-primary');
                    btn.classList.add('btn-sky-secondary');
                }
            });

            // Highlight active button
            const activeBtn = document.getElementById('btn' + view.charAt(0).toUpperCase() + view.slice(1));
            if (activeBtn) {
                activeBtn.classList.remove('btn-sky-secondary');
                activeBtn.classList.add('btn-sky-primary');
            }
        }

        function selectItem(name) {
            const detailsDiv = document.getElementById('fileDetails');
            detailsDiv.innerHTML = `
                <i class="fa-solid fa-file-circle-check" style="font-size: 3rem; color: #3996ff;"></i>
                <h4 class="mt-3">${name}</h4>
                <p class="text-muted mb-3">Selected</p>
                <div class="d-grid gap-2">
                    <button class="btn btn-sky-primary btn-sm">
                        <i class="fa-solid fa-download me-1"></i> Download
                    </button>
                    <button class="btn btn-sky-secondary btn-sm">
                        <i class="fa-solid fa-pen me-1"></i> Rename
                    </button>
                    <button class="btn btn-outline-danger btn-sm">
                        <i class="fa-solid fa-trash me-1"></i> Delete
                    </button>
                </div>
            `;
        }
    </script>
}
