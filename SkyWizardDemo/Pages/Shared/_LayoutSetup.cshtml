<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />
    <link href="~/theme/css/sky-hero-d.css" rel="stylesheet" />
    <link href="~/css/site-additions.css" rel="stylesheet" />
</head>

<body id="@(ViewData["BodyId"] ?? string.Empty)" class="@(ViewData["BodyClass"] ?? "wizard-theme")">
    <div class="wizard-shell">
        <div class="wizard-brand">
            <div class="wizard-brand-mark">
                <img src="~/img/Logomark.svg" alt="SkyCMS logo" class="wizard-logo" />
                <span>SkyCMS</span>
            </div>
        </div>

        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
