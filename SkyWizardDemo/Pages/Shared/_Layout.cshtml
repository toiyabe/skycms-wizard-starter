<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SkyCMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />
    <link href="~/theme/css/sky-hero-d.css" rel="stylesheet" />
    <link href="~/css/site-additions.css" rel="stylesheet" />
    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="@(ViewData["BodyClass"] ?? "wizard-theme")" style="background-color: #d9e9f8;">
    <partial name="_CosmosMainMenuPartial" />

    <div class="wizard-shell">
        @RenderBody()
    </div>

    <footer class="text-center py-4" style="background: rgba(255, 255, 255, 0.3); backdrop-filter: blur(10px); margin-top: 3rem;">
        <div class="container">
            <p class="mb-0" style="color: #10233d;">
                &copy; 2026 SkyCMS - <a href="#" style="color: #1d65c8;">Privacy</a> | <a href="#" style="color: #1d65c8;">Terms</a>
            </p>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
