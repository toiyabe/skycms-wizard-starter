@using Cosmos.Cms.Common.Services.Configurations
@using Microsoft.Extensions.Options
@using Sky.Editor.Data.Logic
@using Sky.Editor.Services.EditorSettings
@model ArticleViewModel
@inject IEditorSettings options
@{
    ViewData["Title"] = "Publish Website";
}
<div class="cwps-editor-container pt-3">
    <div class="container pt-2">
        <div class="row">
            <div class="col text-light">
                <h3>Publish Website</h3>
                <hr />
                <p>
                    Clicking the button below does two things:
                </p>
                <ul>
                    <li>If static web pages are enabled, publishes a fresh copy of all of them.</li>
                    <li>If a CDN is configured, refreshes the Content Delivery Network (CDN) cache.</li>
                </ul>
                <br />
                <button id="btnPublish" class="btn btn-sm btn-success" onclick="publish()">Publish Website</button>
                
                <!-- Success Alert Banner -->
                <div id="successAlert" class="alert alert-success alert-dismissible fade mt-4" role="alert" style="display: none;">
                    <strong>Success!</strong> Website publishing completed successfully!
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true"><i class="fa-solid fa-circle-check"></i></span>
                    </button>
                </div>
                
                <!-- Progress Bar -->
                <div id="progressContainer" class="mt-4" style="display: none;">
                    <div class="progress" style="height: 30px;">
                        <div id="publishProgressBar" 
                             class="progress-bar progress-bar-striped progress-bar-animated bg-success" 
                             role="progressbar" 
                             aria-valuenow="0" 
                             aria-valuemin="0" 
                             aria-valuemax="100" 
                             style="width: 0%">
                            0%
                        </div>
                    </div>
                    <p id="statusMsg" class="mt-2 text-light"></p>
                </div>

                <div style="padding-bottom: 30px; padding-top: 30px;">
                    <p>
                        <span class="badge badge-warning">WARNING: </span>
                        When publishing, websites with large amounts of content may experience temporary performance degradation
                        as caching mechanisms reload content.
                    </p>
                </div>
                
                <div class="row" id="msgBox">
                    <div id="purgeDetails"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Toast Notification Container -->
<div class="position-fixed" style="top: 250px; left: 50%; transform: translateX(-50%); z-index: 9999;" id="toastContainer"></div>

<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@latest/dist/browser/signalr.min.js"></script>
<script>
    const staticWebsite = @options.StaticWebPages.ToString().ToLower();
    let publishConnection = null;

    // Initialize SignalR connection
    async function initializeSignalR() {
        if (publishConnection && publishConnection.state === signalR.HubConnectionState.Connected) {
            return publishConnection;
        }

        publishConnection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/publishing-progress")
            .withAutomaticReconnect()
            .configureLogging(signalR.LogLevel.Information)
            .build();

        publishConnection.on("ReceiveProgress", (data) => {
            updateProgress(data);
        });

        publishConnection.onreconnecting(() => {
            $("#statusMsg").html("Connection lost. Reconnecting...");
        });

        publishConnection.onreconnected(() => {
            $("#statusMsg").html("Connection restored. Publishing continues...");
        });

        publishConnection.onclose(() => {
            console.log("SignalR connection closed");
        });

        try {
            await publishConnection.start();
            console.log("SignalR Connected");
        } catch (err) {
            console.error("SignalR Connection Error: ", err);
            $("#statusMsg").html("Error connecting to progress updates. Please refresh the page.");
        }

        return publishConnection;
    }

    function updateProgress(data) {
        const progressBar = $("#publishProgressBar");
        const statusMsg = $("#statusMsg");

        if (progressBar.length) {
            progressBar.css("width", data.progressPercentage + "%");
            progressBar.attr("aria-valuenow", data.progressPercentage);
            progressBar.text(data.progressPercentage + "%");
        }

        if (statusMsg.length) {
            let message = data.message;
            if (data.currentPage && data.totalPages) {
                message += ` (${data.currentPage}/${data.totalPages})`;
            }
            statusMsg.html(message);
        }

        console.log(`Progress: ${data.progressPercentage}% - ${data.message}`);
    }

    function showToast(title, message, type = 'success') {
        const toastId = 'toast-' + Date.now();
        const bgClass = type === 'success' ? 'bg-success' : type === 'error' ? 'bg-danger' : 'bg-info';
        
        const toastHtml = `
            <div id="${toastId}" class="toast" role="alert" aria-live="assertive" aria-atomic="true" style="min-width: 300px;">
                <div class="toast-header ${bgClass} text-white">
                    <strong class="mr-auto">${title}</strong>
                    <button type="button" class="ml-2 mb-1 close text-white" data-dismiss="toast" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="toast-body">
                    ${message}
                </div>
            </div>
        `;
        
        $("#toastContainer").append(toastHtml);
        const toast = $(`#${toastId}`);
        toast.toast({ delay: 5000 });
        toast.toast('show');
    }

    async function publish() {
        try {
            // Hide any previous success alert
            $("#successAlert").fadeOut();
            
            // Show progress UI
            $("#progressContainer").show();
            $("#btnPublish").prop("disabled", true);
            $("#publishProgressBar").css("width", "0%").text("0%");
            $("#statusMsg").html("Initializing...");

            // Connect to SignalR
            await initializeSignalR();

            if (staticWebsite) {
                $("#statusMsg").html("Starting static page generation...");

                // Single API call - server handles everything
                const response = await fetch('@Url.Action("PublishStaticPages")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    body: JSON.stringify([]) // Empty array = publish all pages
                });

                if (!response.ok) {
                    throw new Error(`Publishing failed: ${response.statusText}`);
                }

                const result = await response.json();
                console.log('Publishing completed:', result);
            } else {
                $("#statusMsg").html("Static pages disabled. Refreshing CDN only...");
            }

            // CDN refresh
            $("#statusMsg").html("Refreshing CDN cache...");
            const cdnResponse = await fetch('@Url.Action("RefreshCdn")');
            
            if (cdnResponse.ok) {
                const cdnResult = await cdnResponse.json();
                
                // Display CDN purge details
                if (cdnResult && cdnResult.length > 0) {
                    let detailsHtml = '<div class="alert alert-info mt-3"><h5>CDN Purge Results:</h5><ul>';
                    cdnResult.forEach(r => {
                        detailsHtml += `<li><strong>${r.provider}:</strong> ${r.success ? 'Success' : 'Failed'} ${r.message ? '- ' + r.message : ''}</li>`;
                    });
                    detailsHtml += '</ul></div>';
                    $("#purgeDetails").html(detailsHtml);
                }
            }

            // Complete - Show success indicators
            $("#publishProgressBar")
                .removeClass("progress-bar-animated")
                .addClass("bg-success")
                .css("width", "100%")
                .text("✓ 100%");
            $("#statusMsg").html("Publishing completed successfully!");
            
            // Show alert banner with fade-in effect
            $("#successAlert").fadeIn();
            
            // Show toast notification
            showToast('Publishing Complete', 'Your website has been published successfully!', 'success');

        } catch (error) {
            console.error("Publishing error:", error);
            $("#publishProgressBar")
                .removeClass("bg-success")
                .addClass("bg-danger");
            $("#statusMsg").html("Error: " + error.message);
            
            // Show error toast
            showToast('Publishing Failed', error.message, 'error');
        } finally {
            $("#btnPublish").prop("disabled", false);
            
            // Disconnect SignalR after a brief delay
            setTimeout(async () => {
                if (publishConnection) {
                    await publishConnection.stop();
                    publishConnection = null;
                }
            }, 3000);
        }
    }

    // Cleanup on page unload
    window.addEventListener('beforeunload', async () => {
        if (publishConnection) {
            await publishConnection.stop();
        }
    });
</script>

@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
